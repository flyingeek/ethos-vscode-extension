{
  "name": "ethos-sim-manager",
  "displayName": "Ethos Simulator Manager",
  "description": "Add and manage Ethos simulator firmware from VS Code",
  "version": "0.4.0",
  "publisher": "flyingeek",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingeek/ethos-sim-manager"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "bsongis.ethos"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Ethos Simulator Manager",
      "properties": {
        "ethosSimManager.simulatorFolder": {
          "type": "string",
          "default": "simulator",
          "description": "Relative path to the simulator directory within the workspace.",
          "scope": "resource"
        },
        "ethosSimManager.telemetrySpeed": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "description": "Default telemetry replay speed multiplier (1 = real-time, 2 = double speed).",
          "scope": "resource"
        },
        "ethosSimManager.telemetryLoop": {
          "type": "boolean",
          "default": false,
          "description": "Whether telemetry playback loops back to the beginning when the file ends.",
          "scope": "resource"
        },
        "ethosSimManager.statusBarEnable": {
          "type": "boolean",
          "default": true,
          "description": "Show or hide the Ethos status bar item.",
          "scope": "resource"
        },
        "ethosSimManager.statusBarText": {
          "type": "string",
          "default": "$(radio-tower) ${firmware}${versionSuffix}",
          "description": "Status bar label. Supports ${firmware}, ${version}, and ${versionSuffix} placeholders. ${versionSuffix} renders @<version> only when version is not nightly26.",
          "scope": "resource"
        },
        "ethosSimManager.statusBarCommand": {
          "type": "string",
          "default": "ethosSimManager.showSimMenu",
          "description": "Command to run when clicking the Ethos status bar item.",
          "scope": "resource"
        },
        "ethosSimManager.statusBarTooltip": {
          "type": "string",
          "default": "Ethos: Show Menu",
          "description": "Tooltip shown on the Ethos status bar item.",
          "scope": "resource"
        },
        "ethosSimManager.firmware": {
          "type": "string",
          "default": "",
          "description": "Active simulator firmware identifier.",
          "scope": "resource"
        },
        "ethosSimManager.version": {
          "type": "string",
          "default": "nightly26",
          "description": "Active simulator firmware version.",
          "scope": "resource"
        }
      }
    },
    "commands": [
      {
        "command": "ethosSimManager.addSimulator",
        "title": "Ethos Sim Manager: Add Simulator"
      },
      {
        "command": "ethosSimManager.setSimulator",
        "title": "Ethos Sim Manager: Set Simulator"
      },
      {
        "command": "ethosSimManager.showSimMenu",
        "title": "Ethos Sim Manager: Show Menu"
      },
      {
        "command": "ethosSimManager.playTelemetry",
        "title": "Ethos Sim Manager: Play Telemetry CSV"
      },
      {
        "command": "ethosSimManager.stopTelemetry",
        "title": "Ethos Sim Manager: Stop Telemetry"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
