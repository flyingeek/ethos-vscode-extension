{
  "name": "ethos-sim-manager",
  "displayName": "Ethos Simulator Manager",
  "description": "Add and manage Ethos simulator firmware from VS Code",
  "version": "0.2.1",
  "publisher": "flyingeek",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingeek/ethos-sim-manager"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "extensionDependencies": ["bsongis.ethos"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Ethos Simulator Manager",
      "properties": {
        "ethos.simulatorFolder": {
          "type": "string",
          "default": "simulator",
          "description": "Relative path to the simulator directory within the workspace.",
          "scope": "resource"
        }
      }
    },
    "commands": [
      {
        "command": "ethos.addSimulator",
        "title": "Ethos: Add Simulator"
      },
      {
        "command": "ethos.setSimulator",
        "title": "Ethos: Set Simulator"
      },
      {
        "command": "ethos.showSimMenu",
        "title": "Ethos: Show Menu"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "jsonc-parser": "^3.2.0"
  }
}
