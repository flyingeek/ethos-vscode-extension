{
  "name": "ethos-sim-manager",
  "displayName": "Ethos Simulator Manager",
  "description": "Add and manage Ethos simulator firmware from VS Code",
  "version": "0.3.0",
  "publisher": "flyingeek",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingeek/ethos-sim-manager"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "extensionDependencies": ["bsongis.ethos"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Ethos Simulator Manager",
      "properties": {
        "ethos.simulatorFolder": {
          "type": "string",
          "default": "simulator",
          "description": "Relative path to the simulator directory within the workspace.",
          "scope": "resource"
        },
        "ethos.telemetrySpeed": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "description": "Default telemetry replay speed multiplier (1 = real-time, 2 = double speed).",
          "scope": "resource"
        },
        "ethos.telemetryLoop": {
          "type": "boolean",
          "default": false,
          "description": "Whether telemetry playback loops back to the beginning when the file ends.",
          "scope": "resource"
        },
        "ethos.statusBarEnable": {
          "type": "boolean",
          "default": true,
          "description": "Show or hide the Ethos status bar item.",
          "scope": "resource"
        },
        "ethos.statusBarText": {
          "type": "string",
          "default": "$(radio-tower) ${firmware}@${version}",
          "description": "Status bar label. Supports ${firmware} and ${version} placeholders.",
          "scope": "resource"
        },
        "ethos.statusBarCommand": {
          "type": "string",
          "default": "ethos.showSimMenu",
          "description": "Command to run when clicking the Ethos status bar item.",
          "scope": "resource"
        },
        "ethos.statusBarTooltip": {
          "type": "string",
          "default": "Ethos: Show Menu",
          "description": "Tooltip shown on the Ethos status bar item.",
          "scope": "resource"
        }
      }
    },
    "commands": [
      {
        "command": "ethos.addSimulator",
        "title": "Ethos: Add Simulator"
      },
      {
        "command": "ethos.setSimulator",
        "title": "Ethos: Set Simulator"
      },
      {
        "command": "ethos.showSimMenu",
        "title": "Ethos: Show Menu"
      },
      {
        "command": "ethos.playTelemetry",
        "title": "Ethos: Play Telemetry CSV"
      },
      {
        "command": "ethos.stopTelemetry",
        "title": "Ethos: Stop Telemetry"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "jsonc-parser": "^3.2.0"
  }
}
