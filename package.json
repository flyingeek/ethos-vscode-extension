{
  "name": "ethos-vscode-extension",
  "displayName": "Ethos VSCode Extension",
  "description": "Telemetry replay for the Ethos Simulator",
  "version": "0.6.3",
  "publisher": "flyingeek",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingeek/ethos-vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "bsongis.ethos"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Ethos VSCode Extension",
      "properties": {
        "ethosExt.telemetryCustomSpeed": {
          "type": "number",
          "minimum": 0.1,
          "description": "Custom replay speed multiplier for telemetry playback.",
          "scope": "resource"
        },
        "ethosExt.radio": {
          "type": "object",
          "scope": "resource",
          "description": "Configuration for radio USB/HID connection.",
          "properties": {
            "vendorId": {
              "type": "string",
              "default": "0483",
              "description": "USB vendor ID (hex, no 0x prefix) of the radio HID device."
            },
            "productId": {
              "type": "string",
              "default": "5750",
              "description": "USB product ID (hex, no 0x prefix) of the radio HID device."
            },
            "retries": {
              "type": "number",
              "default": 10,
              "minimum": 1,
              "description": "Number of HID open attempts before giving up."
            },
            "retryDelay": {
              "type": "number",
              "default": 1.0,
              "minimum": 0.1,
              "description": "Delay in seconds between HID open retries."
            },
            "nameHint": {
              "type": "string",
              "default": "FrSky",
              "description": "Manufacturer name hint used for fuzzy serial port matching when VID/PID is unavailable."
            },
            "serialBaud": {
              "type": "number",
              "default": 115200,
              "minimum": 1200,
              "description": "Baud rate for the radio serial debug console."
            }
          }
        },
        "ethosExt.deploy": {
          "type": "object",
          "scope": "resource",
          "description": "Configuration for the Deploy to simulator command.",
          "properties": {
            "app": {
              "type": "string",
              "description": "Workspace-relative path to the source app folder (e.g. src/gps-qrcode)."
            },
            "manifest": {
              "type": "string",
              "default": "",
              "description": "Workspace-relative path to the Ethos Lua manifest file. If set (non-empty), only files listed in the manifest are copied; otherwise all files are copied."
            },
            "steps": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "A .js/.mjs path (run via Node fork) or a shell command (run via exec). Use ${destPath} and ${sourcePath} as substitution variables."
                  },
                  {
                    "type": "object",
                    "required": ["script"],
                    "properties": {
                      "script": {
                        "type": "string",
                        "description": "A .js/.mjs path or shell command."
                      },
                      "args": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Additional arguments passed to fork() for .mjs scripts, or appended to the command for exec."
                      },
                      "env": {
                        "type": "object",
                        "additionalProperties": { "type": "string" },
                        "description": "Extra environment variables merged into the step's environment."
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              },
              "default": [],
              "description": "Post-deploy commands. Each item is a string or an object with script, args, and env."
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "ethosExt.playTelemetry",
        "title": "Ethos: Play Telemetry CSV"
      },
      {
        "command": "ethosExt.stopTelemetry",
        "title": "Ethos: Stop Telemetry"
      },
      {
        "command": "ethosExt.setTelemetry",
        "title": "Ethos: Set Telemetry Value"
      },
      {
        "command": "ethosExt.deploySimulator",
        "title": "Ethos: Deploy to Simulator"
      },
      {
        "command": "ethosExt.deployRadio",
        "title": "Ethos: Deploy to Radio"
      },
      {
        "command": "ethosExt.deployRadioLua",
        "title": "Ethos: Deploy to Radio (Lua only)"
      },
      {
        "command": "ethosExt.deployRadioFast",
        "title": "Ethos: Deploy to Radio (fast)"
      },
      {
        "command": "ethosExt.radioDebug",
        "title": "Ethos: Radio Debug"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "node-hid": "^3.3.0"
  },
  "overrides": {
    "node-addon-api": "^8.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/node": "18.x",
    "@types/node-hid": "^1.3.4",
    "@types/vscode": "^1.85.0",
    "node-gyp": "^10.2.0",
    "typescript": "^5.3.0"
  }
}
