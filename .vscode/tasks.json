{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "label": "npm: compile"
    },
    {
      "type": "npm",
      "script": "watch",
      "group": "build",
      "problemMatcher": ["$tsc-watch"],
      "isBackground": true,
      "label": "npm: watch"
    },
    {
      "type": "npm",
      "script": "refresh-lock",
      "group": "build",
      "problemMatcher": [],
      "isBackground": true,
      "label": "npm: refresh-lock"
    },
    {
      "label": "release: tag and push",
      "type": "shell",
      "command": "npm run release -- ${input:releaseTag}",
      "problemMatcher": [],
      "group": "build"
    }
  ],
  "inputs": [
    {
      "id": "releaseTag",
      "type": "promptString",
      "description": "Tag name to create and push",
      "default": "release/<version>"
    }
  ]
}
